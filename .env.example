# ============================================================
# ChristianCM2 — Poudlard Maths
# Variables d'environnement
# ============================================================
# Copier ce fichier vers .env.local pour le développement local
# Et configurer ces mêmes variables dans Vercel → Settings → Environment Variables
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
# Récupérables dans Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Clé service_role : UNIQUEMENT côté serveur (jamais commitée, jamais exposée au navigateur)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Anthropic Claude API ──────────────────────────────────
# Récupérable sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://christiancm2.vercel.app
NEXT_PUBLIC_NB_EXOS_PAR_JOUR=30
